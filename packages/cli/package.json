  "license": "MIT",
  "author": "sebuzdugan",
  "dependencies": {
    "@sebuzdugan/crosscheck": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  }
}

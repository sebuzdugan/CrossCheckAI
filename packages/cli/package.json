{
  "name": "@sebuzdugan/crosscheck-cli",
  "version": "0.1.0",
  "description": "CLI for CrossCheckAI — ask the panel a question from your terminal.",
  "type": "module",
  "bin": {
    "crosscheck": "./dist/index.js"
  },
